# Copy to `.env` in the repo root for `docker compose`. Never commit `.env`.
#
# Compose loads this file automatically for variable substitution (secrets must not be committed).

# Required — minimum 32 characters. Generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# MySQL (Docker Compose). Compose substitutes these into the mysql service and DATABASE_URL for backend/worker.
# Use strong values in any shared or production environment.
MYSQL_PASSWORD=rca_pass
MYSQL_ROOT_PASSWORD=root_pass
