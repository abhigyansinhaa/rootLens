# Copy to .env and fill in values. Never commit real secrets.

# Required: min 32 characters, not a placeholder (see app.config FORBIDDEN_SECRET_KEYS).
SECRET_KEY=

# Required: SQLAlchemy URL (Docker Compose example below).
DATABASE_URL=mysql+pymysql://rca_user:rca_pass@mysql:3306/rca_db

# Optional: Redis for RQ worker-backed analyses (omit for BackgroundTasks mode).
# REDIS_URL=redis://redis:6379/0
