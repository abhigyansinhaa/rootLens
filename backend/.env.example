# Copy to `backend/.env` for local runs (or use Docker Compose with repo-root `.env` from `env.example`).

# Never commit real secrets.

# Required: min 32 characters, not a placeholder (see app.config FORBIDDEN_SECRET_KEYS).
SECRET_KEY=

# Required: SQLAlchemy URL. Match user/password to your MySQL instance.
# With Docker Compose, DB credentials are set in repo-root `.env` (see ../env.example); Compose builds DATABASE_URL for services.
DATABASE_URL=mysql+pymysql://rca_user:rca_pass@127.0.0.1:3306/rca_db

# Optional: Redis for RQ worker-backed analyses (omit for BackgroundTasks mode).
# REDIS_URL=redis://redis:6379/0
